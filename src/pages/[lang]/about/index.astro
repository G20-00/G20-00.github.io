---
import Layout from '../../../layouts/Layout.astro';
import BottomNav from '../../../components/BottomNav.astro';
import Section from '../../../components/Section.astro';
import ExperienceItem from '../../../components/ExperienceItem.astro';

import esTranslations from '../../../data/i18n/es.json';
import enTranslations from '../../../data/i18n/en.json';

export function getStaticPaths() {
  // Check if required data files exist
  const dataFiles = import.meta.glob('/src/data/*.json');
  const hasProfile = '/src/data/profile.json' in dataFiles;
  const hasExperience = '/src/data/experience.json' in dataFiles;
  
  // Only generate pages if required files exist
  if (!hasProfile || !hasExperience) {
    return [];
  }
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const currentLang = (lang === 'en' ? 'en' : 'es') as 'es' | 'en';
const t = currentLang === 'en' ? enTranslations : esTranslations;

// Import data (safe because getStaticPaths already verified they exist)
const profileDataImport = await import('../../../data/profile.json');
const experienceDataImport = await import('../../../data/experience.json');
const skillsDataImport = await import('../../../data/skills.json');
const profile = profileDataImport.default || profileDataImport;
const experience = experienceDataImport.default || experienceDataImport;
const skills = skillsDataImport.default || skillsDataImport;

const profileData = profile[currentLang];
const experienceData = experience[currentLang];

// Define skill categories to display
const skillCategories = ['frontend', 'backend', 'tools', 'cloud'] as const;
---

<Layout title={`${t.about.title} - ${profileData.name}`} description={t.about.bio} lang={currentLang}>
  <div class="mx-auto flex w-full flex-col lg:flex-row min-h-[calc(100vh-80px)] overflow-y-auto [&>*:last-child]:pb-20 px-4 sm:px-6 lg:px-24 xl:px-32 2xl:px-40">
    <Section id="about" title={t.about.title}>
    <div class="max-w-none text-gray-700 dark:text-gray-400 mb-6 sm:mb-12">
      <p class="mb-3 sm:mb-4 text-xs sm:text-sm lg:text-base leading-relaxed">{t.about.bio}</p>
    </div>

    <!-- Skills Section -->
    <h3 class="text-sm sm:text-base lg:text-xl font-bold text-gray-900 dark:text-white mb-4 sm:mb-6 mt-8 sm:mt-12">{t.skills?.title}</h3>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 sm:gap-8 mb-8 sm:mb-12">
      {skillCategories.map((category) => (
        <div>
          <h4 class="text-xs sm:text-sm lg:text-base font-semibold text-gray-900 dark:text-white mb-3">{t.skills?.[category]}</h4>
          <div class="flex flex-wrap gap-2">
            {skills[category].map((skill) => (
              <span class="inline-block bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 text-xs lg:text-sm px-3 py-1.5 rounded-full">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Experience Section -->
    <h3 class="text-sm sm:text-base lg:text-xl font-bold text-gray-900 dark:text-white mb-4 sm:mb-6 mt-8 sm:mt-12">{t.experience?.title}</h3>
    <div>
      {experienceData.map((item) => (
        <ExperienceItem
          company={item.company}
          role={item.role}
          startDate={item.startDate}
          endDate={item.endDate}
          current={item.current}
          summary={item.summary}
        />
      ))}
    </div>
  </Section>
  </div>

  <BottomNav currentLang={currentLang} currentPage="about" />
</Layout>
