---
interface Props {
  projects: Array<{
    id: string;
    title: string;
    image: string;
    url?: string;
    description?: string;
  }>;
  lang?: 'es' | 'en';
}

const { projects = [], lang = 'es' } = Astro.props;

const translations = {
  es: {
    fallbackDescription: 'Diseño visual impactante',
    carousel: 'Carrusel de proyectos'
  },
  en: {
    fallbackDescription: 'Impactful visual design',
    carousel: 'Projects carousel'
  }
};

const t = translations[lang];
---

{
  projects.length > 0 && (
    <section class="project-slider" aria-label={t.carousel} data-autoplay="4500">
      <div class="project-slider__inner">
        <div class="project-slider__viewport">
          <div class="project-slider__track">
            {projects.map((project, index) => (
              <article class="project-slider__slide" data-index={index}>
                {project.url ? (
                  <a
                    href={project.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="project-slider__card"
                  >
                    <img
                      src={project.image}
                      alt={project.title}
                      class="project-slider__image"
                      loading={index === 0 ? 'eager' : 'lazy'}
                    />
                    <div class="project-slider__overlay">
                      <div class="project-slider__content">
                        <h3 class="project-slider__title">{project.title}</h3>
                        <p class="project-slider__description">
                          {project.description || t.fallbackDescription}
                        </p>
                      </div>
                    </div>
                  </a>
                ) : (
                  <div class="project-slider__card">
                    <img
                      src={project.image}
                      alt={project.title}
                      class="project-slider__image"
                      loading={index === 0 ? 'eager' : 'lazy'}
                    />
                    <div class="project-slider__overlay">
                      <div class="project-slider__content">
                        <h3 class="project-slider__title">{project.title}</h3>
                        <p class="project-slider__description">
                          {project.description || t.fallbackDescription}
                        </p>
                      </div>
                    </div>
                  </div>
                )}
              </article>
            ))}
          </div>
        </div>

        <div class="project-slider__dots" aria-label="Slide navigation">
          {projects.map((project, index) => (
            <button
              type="button"
              class={`project-slider__dot ${index === 0 ? 'is-active' : ''}`}
              data-index={index}
              aria-label={`${index + 1}. ${project.title}`}
            />
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .project-slider {
    width: 100%;
    padding: 0.5rem 0 0.75rem;
    display: flex;
    justify-content: center;
  }

  @media (min-width: 1024px) {
    .project-slider {
      width: 100%;
      padding: 0.5rem 0 0.75rem;
    }

    .project-slider__inner {
      width: 100%;
      min-width: 280px;
    }

    .project-slider__viewport {
      border-radius: 1.5rem;
    }

    .project-slider__card {
      aspect-ratio: 1 / 1;
      border-radius: 1.5rem;
      box-shadow: none;
      border: 2px solid #e5e7eb;
    }

    html.dark .project-slider__card {
      border: 2px solid #374151;
    }
  }

  @media (min-width: 1536px) {
    .project-slider__card {
      aspect-ratio: 1 / 1;
    }
  }

  .project-slider__inner {
    width: 100%;
    max-width: 100%;
    min-width: 250px;
  }

  .project-slider__viewport {
    overflow: hidden;
    border-radius: 1.5rem;
  }

  .project-slider__track {
    display: flex;
    transition: transform 0.45s ease;
    will-change: transform;
  }

  .project-slider__slide {
    min-width: 100%;
    box-sizing: border-box;
    padding: 0 0.15rem;
  }

  .project-slider__card {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 1.5rem;
    overflow: hidden;
    text-decoration: none;
    background: transparent;
    box-shadow: none;
    border: 2px solid #e5e7eb;
  }

  html.dark .project-slider__card {
    border: 2px solid #374151;
  }

  /* Mobile - Horizontal line style */
  @media (max-width: 1023px) {
    .project-slider {
      padding: 1.5rem 0 1rem;
      width: 100%;
    }

    .project-slider__inner {
      width: 100%;
      max-width: 100%;
      padding: 0 1rem;
    }

    .project-slider__viewport {
      border-radius: 0.75rem;
    }

    .project-slider__slide {
      min-width: 100%;
      padding: 0;
    }

    .project-slider__card {
      aspect-ratio: 16 / 5;
      border-radius: 0.75rem;
      box-shadow: none;
      border: 2px solid #e5e7eb;
    }

    html.dark .project-slider__card {
      border: 2px solid #374151;
    }

    .project-slider__overlay {
      padding: 0.5rem;
    }

    .project-slider__title {
      font-size: 0.85rem;
    }

    .project-slider__description {
      font-size: 0.7rem;
      margin: 0.15rem 0 0;
      display: none;
    }

    .project-slider__dots {
      gap: 0.25rem;
      margin-top: 0.5rem;
    }

    .project-slider__dot {
      width: 0.3rem;
      height: 0.3rem;
    }

    .project-slider__dot.is-active {
      width: 1rem;
    }
  }

  .project-slider__image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    object-position: center;
  }

  .project-slider__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 0.75rem;
    background: transparent;
  }

  .project-slider__content {
    background: transparent;
    color: #000000;
    padding: 0;
    border-radius: 0;
    text-align: center;
    width: 100%;
  }

  html.dark .project-slider__content {
    background: transparent;
    color: #ffffff;
  }

  .project-slider__title {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: inherit;
  }

  .project-slider__description {
    margin: 0.25rem 0 0;
    font-size: 0.75rem;
    line-height: 1.3;
    color: inherit;
    opacity: 0.95;
    display: none;
  }

  .project-slider__dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.3rem;
    margin-top: 0.6rem;
  }

  .project-slider__dot {
    width: 0.35rem;
    height: 0.35rem;
    border: 0;
    border-radius: 999px;
    background: #d1d5db;
    cursor: pointer;
    transition:
      width 0.25s ease,
      opacity 0.25s ease,
      background 0.25s ease;
  }

  .project-slider__dot.is-active {
    width: 1.15rem;
    background: #1f2937;
  }

  .project-slider__dot:hover {
    opacity: 0.85;
  }

  .project-slider__dot:focus-visible {
    outline: 2px solid #111827;
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .project-slider__track,
    .project-slider__dot {
      transition: none;
    }
  }

  :global(.dark) .project-slider__dot {
    background: rgba(255, 255, 255, 0.28);
  }

  :global(.dark) .project-slider__dot.is-active {
    background: #ffffff;
  }
</style>

<script>
  const initProjectSlider = (root) => {
    if (!root || root.dataset.initialized === 'true') return;
    root.dataset.initialized = 'true';

    const track = root.querySelector('.project-slider__track');
    const slides = Array.from(root.querySelectorAll('.project-slider__slide'));
    const dots = Array.from(root.querySelectorAll('.project-slider__dot'));
    const autoplayDelay = Number(root.dataset.autoplay || 4500);

    if (!track || slides.length === 0) return;

    let currentIndex = 0;
    let autoplayId;
    let touchStartX = 0;
    let touchEndX = 0;

    // Respect reduced motion preferences
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const updateSlider = () => {
      track.style.transform = `translate3d(-${currentIndex * 100}%, 0, 0)`;

      dots.forEach((dot, index) => {
        dot.classList.toggle('is-active', index === currentIndex);
      });
    };

    const goTo = (index) => {
      currentIndex = (index + slides.length) % slides.length;
      updateSlider();
    };

    const next = () => {
      goTo(currentIndex + 1);
    };

    const stopAutoplay = () => {
      if (autoplayId) {
        window.clearInterval(autoplayId);
        autoplayId = undefined;
      }
    };

    const startAutoplay = () => {
      if (reduceMotion || slides.length < 2) return;
      stopAutoplay();
      autoplayId = window.setInterval(next, autoplayDelay);
    };

    const restartAutoplay = () => {
      stopAutoplay();
      startAutoplay();
    };

    // Dot navigation
    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const index = Number(dot.dataset.index);
        goTo(index);
        restartAutoplay();
      });
    });

    // Swipe support on touch devices
    root.addEventListener(
      'touchstart',
      (event) => {
        touchStartX = event.touches[0].clientX;
        touchEndX = touchStartX;
      },
      { passive: true }
    );

    root.addEventListener(
      'touchmove',
      (event) => {
        touchEndX = event.touches[0].clientX;
      },
      { passive: true }
    );

    root.addEventListener('touchend', () => {
      const diffX = touchEndX - touchStartX;

      if (Math.abs(diffX) > 40) {
        if (diffX < 0) next();
        else goTo(currentIndex - 1);

        restartAutoplay();
      }
    });

    // Pause autoplay when the user is interacting
    root.addEventListener('mouseenter', stopAutoplay);
    root.addEventListener('mouseleave', startAutoplay);
    root.addEventListener('focusin', stopAutoplay);
    root.addEventListener('focusout', startAutoplay);

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stopAutoplay();
      else startAutoplay();
    });

    updateSlider();
    startAutoplay();
  };

  const mountProjectSliders = () => {
    document.querySelectorAll('.project-slider').forEach(initProjectSlider);
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', mountProjectSliders);
  } else {
    mountProjectSliders();
  }
</script>