---
// Main layout component
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: 'es' | 'en';
}

const { title = 'Portfolio', description = 'Alex Rivera - Full Stack Developer', lang = 'es' } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      // Apply theme BEFORE page renders - pure client-side
      // Default to dark theme
      (function() {
        try {
          const theme = localStorage.getItem('theme');
          if (theme === 'light') {
            document.documentElement.classList.remove('dark');
          } else {
            // Default to dark: 'dark', null, or any other value
            document.documentElement.classList.add('dark');
          }
        } catch (e) {
          // localStorage not available - default to dark
          document.documentElement.classList.add('dark');
        }
      })();
      
      // Force layout recalculation on page load
      (function() {
        document.addEventListener('DOMContentLoaded', function() {
          void document.documentElement.offsetHeight;
        }, { once: true });
      })();
    </script>
  </head>
  <body class="bg-white text-gray-900 dark:bg-gray-900 dark:text-gray-100 flex flex-col w-full overflow-x-hidden">
    <slot />
  </body>
</html>

