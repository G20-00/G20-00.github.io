---
import Layout from '../../layouts/Layout.astro';
import BottomNav from '../../components/BottomNav.astro';
import Section from '../../components/Section.astro';
import ProjectCarousel from '../../components/ProjectCarousel.astro';

import esTranslations from '../../data/i18n/es.json';
import enTranslations from '../../data/i18n/en.json';

// Check if required data files exist
const dataFiles = import.meta.glob('/src/data/*.json');
const hasProfile = '/src/data/profile.json' in dataFiles;
const hasProjects = '/src/data/projects.json' in dataFiles;

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const currentLang = (lang === 'en' ? 'en' : 'es') as 'es' | 'en';
const t = currentLang === 'en' ? enTranslations : esTranslations;

// Import data only if they exist
let profileData = { name: '', role: '', bio_short: '', location: '', email: '' };
let projectsData: any[] = [];

if (hasProfile) {
  const profileImport = await import('../../data/profile.json');
  const profile = profileImport.default || profileImport;
  profileData = profile[currentLang];
}

if (hasProjects) {
  const projectsImport = await import('../../data/projects.json');
  const projects = projectsImport.default || projectsImport;
  projectsData = projects[currentLang];
}
---

<Layout title={`${profileData.name} - ${profileData.role}`} description={profileData.bio_short} lang={currentLang}>
<div class="mx-auto flex w-full flex-col lg:flex-row lg:items-center lg:justify-center lg:gap-8 min-h-[calc(100vh-80px)] px-4 sm:px-6 lg:px-24 xl:px-32 2xl:px-40 lg:pb-6 xl:pb-8 2xl:pb-12">
  
  <div class="order-2 flex w-full items-center justify-center pb-24 lg:order-1 lg:pb-0 lg:max-w-[20%] lg:flex-1 lg:min-w-[250px]">
    <ProjectCarousel projects={projectsData} lang={currentLang} />
  </div>

  <div class="order-1 flex w-full flex-col items-center justify-center px-4 py-8 lg:order-2 lg:flex-1 lg:py-0 lg:px-0 lg:mb-6 xl:mb-8 2xl:mb-12">
    <div class="w-full">
      <Section id="home" title="">
        <div class="mb-8 mt-16 flex items-center justify-center">
          <div class="relative">
            <img 
              src="/images/brand-persona.jpg" 
              alt={profileData.name}
              class="h-48 w-48 rounded-full border-8 border-gray-200 object-cover shadow-lg dark:border-gray-800 lg:h-56 lg:w-56 xl:h-64 xl:w-64 2xl:h-72 2xl:w-72 transition-all duration-300"
            />
          </div>
        </div>

        <div class="w-full px-2 text-center lg:px-0">
          <h2 class="mb-3 text-3xl font-bold text-gray-900 dark:text-white sm:text-4xl lg:text-4xl xl:text-5xl 2xl:text-6xl transition-all">{profileData.name}</h2>
          <p class="mb-6 text-lg text-gray-600 dark:text-gray-400 lg:text-xl xl:text-2xl 2xl:text-3xl transition-all">{profileData.role}</p>
          <p class="mb-8 text-base leading-8 text-gray-700 dark:text-gray-300 sm:text-lg lg:text-lg xl:text-xl 2xl:text-2xl transition-all">
            {profileData.bio_short}
          </p>
          <div class="space-y-3 text-sm sm:space-y-4 sm:text-base lg:text-base xl:text-lg 2xl:text-xl transition-all">
            <p class="text-gray-600 dark:text-gray-400">📍 {profileData.location}</p>
            <p class="text-gray-600 dark:text-gray-400">✉️ <a href={`mailto:${profileData.email}`} class="text-blue-600 hover:underline dark:text-blue-400">{profileData.email}</a></p>
          </div>
        </div>
      </Section>
    </div>
  </div>
</div>

  <BottomNav currentLang={currentLang} currentPage="home" />
</Layout>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }
</style>
